CC ?= gcc
PREFIX ?= /ucrt64
TARGET ?= rmtrash.exe
SRC := src/rmtrash.c

CPPFLAGS ?=
CFLAGS ?= -std=c11 -O2 -Wall -Wextra -DWIN32_LEAN_AND_MEAN
LDFLAGS ?=
LDLIBS := -lshell32

.PHONY: all clean install

all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) $(CPPFLAGS) $(CFLAGS) -o $@ $< $(LDFLAGS) $(LDLIBS)

install: $(TARGET)
	install -d "$(DESTDIR)$(PREFIX)/bin"
	install -m 755 "$(TARGET)" "$(DESTDIR)$(PREFIX)/bin/rmtrash.exe"

clean:
	rm -f "$(TARGET)"
